+                    participants=participants_out,
+                    last_message=None,
+                    unread_count=0,
+                    updated_at=existing_conv.updated_at.isoformat() if existing_conv.updated_at else "",
+                )
+
+    # Create new conversation
+    conv = Conversation(type=conv_type, name=None)
+    db.add(conv)
+    await db.flush()
+
+    # Add participants
+    for uid in all_ids:
