+    ]
+
+    return ConversationOut(
+        id=conv.id,
+        type=conv.type or "direct",
+        name=conv.name,
+        participants=participants_out,
+        last_message=None,
+        unread_count=0,
+        updated_at=conv.updated_at.isoformat() if conv.updated_at else "",
+    )
