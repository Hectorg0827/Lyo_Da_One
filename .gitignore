build-log-sim.txt
build-verify-*.txt
build-verify.log
build_*.txt
pkg_resolve*.log
settings_check.log

# === Prevent one-off helper scripts from being committed at root ===
# Use Sources/ for real app code; keep root clean.
/*.rb
/*.py
/*.sh
/*.txt

# === Prevent stale docs/reports from accumulating in root ===
# Put real docs in a docs/ folder instead.
# (README.md and CHANGELOG.md are allowed)

# === Node/Web development ===
node_modules/
.next/
dist/

# === Python ===
__pycache__/
*.pyc

# === Claude / Agent folders ===
.claude/

# === Misc ===
*.ipa
*.dSYM.zip
*.dSYM
Pods/
build_temp*/
nohup.out
*.tsbuildinfo
